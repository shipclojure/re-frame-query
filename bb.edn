{:paths ["src" "resources"]
 :deps {com.lambdaisland/dotenv {:mvn/version "0.2.5"}}

 :tasks
 {jar {:doc "Build jar with latest version"
       :task (clojure "-T:build jar")}
  bb-repl {:doc "Start a babashka nrepl server"
           :task (shell "bb" "nrepl-server")}
  pom {:doc "Build pom.xml based on deps.edn"
       :task (clojure "-X:deps mvn-pom")}
  deploy {:doc "Deploy the latest release to Clojars"
          :task (clojure "-X:deploy")}
  fmt {:doc "Format all Clojure files with cljfmt"
       :task (shell "cljfmt" "fix" "src" "test" "examples")}
  fmt:check {:doc "Check formatting without modifying files"
             :task (shell "cljfmt" "check" "src" "test" "examples")}
  test:unit {:doc "Run ClojureScript unit tests via shadow-cljs"
             :task (shell "pnpm" "test")}
  test:e2e {:doc "Run Playwright e2e tests against both example apps"
            :task (shell "pnpm" "test:e2e")}}}
